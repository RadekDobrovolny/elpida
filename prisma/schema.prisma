generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Course {
  id               String        @id @default(uuid())
  anonymousUserId  String
  domainRaw        String        @default("")
  domainFinal      String        @default("")
  goalRaw          String        @default("")
  goalFinal        String        @default("")
  experienceRaw    String        @default("")
  experienceFinal  String        @default("")
  quiz             String        @default("[]")
  titleRaw         String        @default("")
  titleFinal       String        @default("")
  currentStep      Int           @default(1)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  messages         ChatMessage[]

  @@index([anonymousUserId])
  @@index([createdAt])
}

model StepSetting {
  id              String   @id @default(cuid())
  anonymousUserId String
  step            Int
  goalText        String   @default("")
  criteriaText    String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([anonymousUserId, step])
  @@index([anonymousUserId])
}

model ChatMessage {
  id        String   @id @default(cuid())
  courseId  String
  role      String
  content   String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId, createdAt])
}
